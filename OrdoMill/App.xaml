<Application
    x:Class="OrdoMill.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:OrdoMill.Converters"
    xmlns:converters2="clr-namespace:SmartApp.Helpers.Converters;assembly=SmartApp.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ignore="http://www.galasoft.ch/ignore"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:OrdoMill.ViewModel"
    DispatcherUnhandledException="App_OnDispatcherUnhandledException"
    StartupUri="Views/Home/SplashScreen.xaml"
    mc:Ignorable="d ignore">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!--  MahApps  -->
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Light.Teal.xaml" />

                <ResourceDictionary Source="pack://application:,,,/Resources/Styles/myStyle.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Resources/IconsXaml.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Resources/GlobalFr.xaml" />

            </ResourceDictionary.MergedDictionaries>
            <Color x:Key="AccentColor">#FF009688</Color>
            <Color x:Key="WhiteColor">#FFFFFFFF</Color>
            <Color x:Key="BlackColor">#FF111111</Color>
            <Color x:Key="Gray2">#FF6E6E6E</Color>
            <Color x:Key="Gray5">#FFE5E5E5</Color>
            <Color x:Key="Gray10">#FFF7F7F7</Color>

            <SolidColorBrush x:Key="AccentColorBrush" Color="#FF009688" />
            <SolidColorBrush x:Key="AccentColorBrush2" Color="#FF80CBC4" />
            <SolidColorBrush x:Key="AccentColorBrush3" Color="#FF00796B" />
            <SolidColorBrush x:Key="AccentColorBrush4" Color="#14009688" />
            <SolidColorBrush x:Key="GrayBrush1" Color="#FFF5F5F5" />
            <SolidColorBrush x:Key="GrayBrush2" Color="#FFD9D9D9" />
            <SolidColorBrush x:Key="GrayBrush4" Color="#FFEAEAEA" />
            <SolidColorBrush x:Key="GrayBrush8" Color="#FF7A7A7A" />
            <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="WhiteColorBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="IdealForegroundColorBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="PrimaryHueDarkBrush" Color="#FF00695C" />
            <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#FF4DB6AC" />

            <converters2:VisibileToCollapsedConverter x:Key="VisibileToCollapsedConverter" />
            <converters2:VisibleToHiddenConverter x:Key="VisibileToHiddenConverter" />
            <converters:MedecinsTypesConvertr x:Key="MedecinsTypesConvertr" />
            <converters2:BoolInvercer x:Key="BoolInverser" />
            <vm:ViewModelLocator x:Key="Locator" d:IsDataSource="True" />
            <converters2:StringToDateConverter x:Key="StringToDateConverter" />
            <converters:RelationshipConverter x:Key="RelationshipConverter" />
            <converters2:VisibleToHiddenConverter x:Key="VisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
