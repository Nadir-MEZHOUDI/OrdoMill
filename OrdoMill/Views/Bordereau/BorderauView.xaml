<UserControl x:Class="OrdoMill.Views.Bordereau.BordereauView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:command="http://www.galasoft.ch/mvvmlight"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dialog="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
             xmlns:extensions="clr-namespace:SmartApp.Helpers.Extensions;assembly=SmartApp.Helpers"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shared="clr-namespace:OrdoMill.Views.Shared"
             d:DesignHeight="500"
             d:DesignWidth="1000"
             dialog:DialogParticipation.Register="{Binding}"
             DataContext="{Binding BordereauxViewModel,
                                   Source={StaticResource Locator}}"
             Style="{DynamicResource CustomUserControl}"
             mc:Ignorable="d">
    <UserControl.InputBindings>
        <KeyBinding Key="S"
                    Command="{Binding SaveCommand}"
                    Modifiers="Control" />
        <KeyBinding Key="N"
                    Command="{Binding AddCommand}"
                    Modifiers="Ctrl" />
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />

        <KeyBinding Key="U"
                    Command="{Binding DeleteCommand}"
                    Modifiers="Control" />
    </UserControl.InputBindings>
    <Grid extensions:MarginSetter.Margin="3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel>
            <WrapPanel.Resources>
                <ResourceDictionary Source="../../Resources/Styles/BarButtonsStyle.xaml" />
            </WrapPanel.Resources>

            <Button Command="{Binding AddCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Add}" />
                    <TextBlock Text="{DynamicResource Addtxt}" />
                </StackPanel>
            </Button>


            <Button Command="{Binding UpdateCommand}">
                <StackPanel Orientation="Horizontal">
                    <ContentControl Content="{DynamicResource Editor}" />
                    <TextBlock Text="{DynamicResource Edit}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding DeleteCommand}">
                <StackPanel Orientation="Horizontal">
                    <ContentControl Content="{DynamicResource Recycle-Bin}" />
                    <TextBlock Text="{DynamicResource Del}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding SaveCommand}" CommandParameter="{Binding SelectedItem.Id}">
                <StackPanel Orientation="Horizontal">
                    <ContentControl Content="{DynamicResource Save}" />
                    <TextBlock Text="{DynamicResource SaveTxt}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding CancelCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Cancel}" />
                    <TextBlock Text="{DynamicResource Canceltxt}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding PrintResumeCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Excel}" />
                    <TextBlock Text="Extract Resume" />
                </StackPanel>
            </Button>
            <Button Command="{Binding PrintEtiquettesCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Excel}" />
                    <TextBlock Text="Extract Etiquettes" />
                </StackPanel>
            </Button>
            <Button Command="{Binding PrintFacturesCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Excel}" />
                    <TextBlock Text="Extract Factures" />
                </StackPanel>
            </Button>
        </WrapPanel>
        <Grid Grid.Row="1" extensions:MarginSetter.Margin="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Label HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="{DynamicResource NumD}" />
            <xctk:IntegerUpDown Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Minimum="0"
                                    TextAlignment="Left"
                                    Value="{Binding SelectedItem.Number,
                                                    Mode=TwoWay}" />
            <Label Grid.Column="2"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="{DynamicResource DateD}" />
            <DatePicker Grid.Column="3" SelectedDate="{Binding SelectedItem.Date, Mode=TwoWay, StringFormat=dd/MM/yyyy}" />
            <Label Grid.Column="4"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="{DynamicResource DateD}" />
            <ToggleButton Grid.Column="5" IsChecked="{Binding SelectedItem.IsFinished}" />
        </Grid>

        <TextBox Grid.Row="2"
                 IsEnabled="{Binding IsEditable,
                                     Converter={StaticResource BoolInverser}}"
                 Style="{DynamicResource SearshTextStyle}"
                 Text="{Binding Path=SearchPattern,
                                UpdateSourceTrigger=PropertyChanged,
                                Mode=TwoWay}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="TextChanged">
                    <command:EventToCommand Command="{Binding SearchCommand, UpdateSourceTrigger=PropertyChanged}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </TextBox>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding ListToDisplay}"
                  SelectedValue="{Binding SelectedItem}">
            <DataGrid.Columns>


                <DataGridCheckBoxColumn Binding="{Binding IsCheck}" />

                <DataGridTextColumn Width="*"
                                    Binding="{Binding Name}"
                                    FontWeight="Bold"
                                    Header="{DynamicResource Num}" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Width="25"
                                            Height="25"
                                            Margin="10,0"
                                            Content="{DynamicResource Archive-Wf}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Date,
                                                      Mode=OneWay,
                                                      StringFormat=dd/MM/yyyy}"
                                    Header="{DynamicResource DateText}" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Width="25"
                                            Height="25"
                                            Margin="10,0"
                                            Content="{DynamicResource Summation}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Factures.Count}"
                                    FontWeight="Bold"
                                    Header="{DynamicResource Factures}" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Height="30" Content="{DynamicResource OrdoIcon}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="*"
                                    Binding="{Binding OrdosCount}"
                                    Header="{DynamicResource Ordonnances}" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Width="25"
                                            Height="25"
                                            Margin="10,0"
                                            Content="{DynamicResource MoneyIcon}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Montant,
                                                      StringFormat=C}"
                                    FontWeight="Bold"
                                    Header="{DynamicResource Montant}" />

                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Content="{DynamicResource CurrencyDz}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <WrapPanel HorizontalAlignment="Center"
                                       Background="Transparent"
                                       Visibility="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                            Path=IsMouseOver,
                                                            Converter={StaticResource VisibileToHiddenConverter}}">
                                <WrapPanel.Resources>
                                    <ResourceDictionary Source="../../Resources/Styles/BarButtonsStyle.xaml" />
                                </WrapPanel.Resources>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.AddCommand}">
                                    <ContentControl Content="{DynamicResource Add}" />
                                </Button>

                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.UpdateCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Editor}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.DeleteCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Recycle-Bin}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.GoToDetailsPage}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Preview}" />
                                </Button>
                            </WrapPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="{Binding AddCommand}"
                              Header="{DynamicResource Addtxt}"
                              Icon="{DynamicResource Add}" />
                    <MenuItem Command="{Binding UpdateCommand}"
                              Header="{DynamicResource Edit}"
                              Icon="{DynamicResource Editor}" />
                    <Separator />

                    <MenuItem Header="{DynamicResource Extraction}" Icon="{DynamicResource Excel}">

                        <MenuItem Header="{DynamicResource Bordereau}" Icon="{DynamicResource Excel}" />
                        <Separator />
                        <MenuItem Command="{Binding PrintResumeCommand}"
                                  Header="Extract Resume"
                                  Icon="{DynamicResource Excel}" />

                        <MenuItem Command="{Binding PrintEtiquettesCommand}"
                                  Header="Extract Etiquettes"
                                  Icon="{DynamicResource Excel}" />

                        <MenuItem Command="{Binding PrintFacturesCommand}"
                                  Header="Extract Factures"
                                  Icon="{DynamicResource Excel}" />
                    </MenuItem>

                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <shared:Pagenation Grid.Row="4" />

    </Grid>
</UserControl>