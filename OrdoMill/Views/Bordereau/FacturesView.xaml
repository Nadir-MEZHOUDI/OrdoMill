<UserControl
    x:Class="OrdoMill.Views.Bordereau.FacturesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialog="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
    xmlns:extensions="clr-namespace:SmartApp.Helpers.Extensions;assembly=SmartApp.Helpers"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shared="clr-namespace:OrdoMill.Views.Shared"
    d:DesignHeight="500"
    d:DesignWidth="849.9"
    dialog:DialogParticipation.Register="{Binding}"
    DataContext="{Binding FacturesViewModel, Source={StaticResource Locator}}"
    Style="{DynamicResource CustomUserControl}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <CollectionViewSource x:Key="GroupedItems" Source="{Binding ListToDisplay}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Bordereau.Name" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding
            Key="S"
            Command="{Binding SaveCommand}"
            Modifiers="Control" />
        <KeyBinding
            Key="N"
            Command="{Binding AddCommand}"
            Modifiers="Ctrl" />
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />

        <KeyBinding
            Key="U"
            Command="{Binding DeleteCommand}"
            Modifiers="Control" />
    </UserControl.InputBindings>
    <Grid extensions:MarginSetter.Margin="3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <WrapPanel>
            <WrapPanel.Resources>
                <ResourceDictionary Source="../../Resources/Styles/BarButtonsStyle.xaml" />
            </WrapPanel.Resources>
            <Button Command="{Binding AddCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Add}" />
                    <TextBlock Text="{DynamicResource Addtxt}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding UpdateCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Editor}" />
                    <TextBlock Text="{DynamicResource Edit}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding DeleteCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Recycle-Bin}" />
                    <TextBlock Text="{DynamicResource Del}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding SaveCommand}" CommandParameter="{Binding SelectedItem.Id}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Save}" />
                    <TextBlock Text="{DynamicResource SaveTxt}" />
                </StackPanel>
            </Button>
            <Button Command="{Binding CancelCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Cancel}" />
                    <TextBlock Text="{DynamicResource Canceltxt}" />
                </StackPanel>
            </Button>
            <Separator />
            <Button Command="{Binding PrintFactureCommand}">
                <StackPanel>
                    <ContentControl Content="{DynamicResource Excel}" />
                    <TextBlock Text="{DynamicResource Extraction}" />
                </StackPanel>
            </Button>
        </WrapPanel>
        <Grid
            Grid.Row="1"
            extensions:MarginSetter.Margin="5,1"
            IsEnabled="{Binding IsEditable}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Content="{DynamicResource NumD}" />

            <mah:NumericUpDown
                Grid.Column="1"
                VerticalAlignment="Center"
                FontWeight="Bold"
                TextAlignment="Center"
                Value="{Binding SelectedItem.Number, Mode=TwoWay}" />
            <Label
                Grid.Column="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Content="{DynamicResource BordereauD}" />
            <ComboBox
                Grid.Column="3"
                VerticalAlignment="Center"
                DisplayMemberPath="Name"
                FontWeight="Bold"
                ItemsSource="{Binding Bordereaux}"
                SelectedItem="{Binding SelectedItem.Bordereau}" />

            <Label
                Grid.Column="4"
                VerticalAlignment="Center"
                Content="{DynamicResource Mc}" />
            <ToggleButton
                Grid.Column="5"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                IsChecked="{Binding SelectedItem.Chronic, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnValidationError=True, ValidatesOnDataErrors=True}" />
            <Label
                Grid.Column="6"
                VerticalAlignment="Center"
                Content="{DynamicResource Hr}" />
            <ToggleButton
                Grid.Column="7"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                IsChecked="{Binding SelectedItem.Out, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnValidationError=True, ValidatesOnDataErrors=True}" />
        </Grid>
        <Grid Grid.Row="2" extensions:MarginSetter.Margin="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBox
                Margin="2"
                IsEnabled="{Binding IsEditable, Converter={StaticResource BoolInverser}}"
                Style="{DynamicResource SearshTextStyle}"
                Text="{Binding Path=SearchPattern, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="TextChanged">
                        <i:InvokeCommandAction Command="{Binding SearchCommand, UpdateSourceTrigger=PropertyChanged}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </TextBox>
            <ComboBox
                Grid.Column="1"
                Margin="2"
                controls:TextBoxHelper.ClearTextButton="True"
                DisplayMemberPath="Name"
                ItemsSource="{Binding Bordereaux}"
                SelectedItem="{Binding SelectedBordereau}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <i:InvokeCommandAction Command="{Binding SearchCommand, UpdateSourceTrigger=PropertyChanged}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </ComboBox>
        </Grid>
        <DataGrid
            Grid.Row="3"
            ItemsSource="{Binding Source={StaticResource GroupedItems}}"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <DataGrid.Columns>

                <DataGridCheckBoxColumn Binding="{Binding IsCheck}" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Number}"
                    Header="N°" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Bordereau.Name}"
                    FontSize="15"
                    FontWeight="Bold"
                    Header="{DynamicResource Bordereau}" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl
                                Height="30"
                                Margin="10,0"
                                Content="{DynamicResource Numbering-Wf}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Bordereau.Date, Mode=OneWay, StringFormat=dd/MM/yyyy}"
                    FontSize="15"
                    FontWeight="Bold"
                    Header="{DynamicResource DateText}" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Height="30" Content="{DynamicResource Summation}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Ordonnances.Count}"
                    Header="{DynamicResource Ordonnances}" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Height="30" Content="{DynamicResource MoneyIcon}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Montant, StringFormat=C}"
                    Header="{DynamicResource Montant}" />
                <DataGridTemplateColumn Header="{DynamicResource CurrencyDz}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Height="30" Content="{DynamicResource CurrencyDz}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridCheckBoxColumn Binding="{Binding Chronic}" Header="{DynamicResource Mc}" />
                <DataGridCheckBoxColumn Binding="{Binding Out}" Header="{DynamicResource Hr}" />
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <WrapPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsMouseOver, Converter={StaticResource VisibileToHiddenConverter}}">
                                <WrapPanel.Resources>
                                    <ResourceDictionary Source="../../Resources/Styles/BarButtonsStyle.xaml" />
                                </WrapPanel.Resources>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.AddCommand}">
                                    <ContentControl Content="{DynamicResource Add}" />
                                </Button>

                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.UpdateCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Editor}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.DeleteCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Recycle-Bin}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.GoToDetailsPage}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Preview}" />
                                </Button>
                            </WrapPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            <!--<ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Expander Background="{DynamicResource GrayBrush4}" IsExpanded="True">
                                            <Expander.Header>
                                                <StackPanel Height="30" Orientation="Horizontal">
                                                    <TextBlock Margin="10,0,0,0"
                                                               FontWeight="Bold"
                                                               Text="{DynamicResource Bordereau}" />
                                                    <TextBlock Margin="10,0,0,0"
                                                               FontWeight="Bold"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Margin="10,0,0,0"
                                                               FontStyle="Italic"
                                                               FontWeight="Bold"
                                                               Text="{Binding ItemCount}" />
                                                    <TextBlock FontStyle="Italic" Text=" Facture(s)" />
                                                </StackPanel>
                                            </Expander.Header>
                                            <ItemsPresenter />
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </ListView.GroupStyle>-->

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        Command="{Binding AddCommand}"
                        Header="{DynamicResource Addtxt}"
                        Icon="{DynamicResource Add}" />
                    <MenuItem
                        Command="{Binding UpdateCommand}"
                        Header="{DynamicResource Edit}"
                        Icon="{DynamicResource Editor}" />
                    <Separator />

                    <MenuItem
                        Command="{Binding PrintFactureCommand}"
                        Header="{DynamicResource Extraction}"
                        Icon="{DynamicResource Print-01}" />

                </ContextMenu>
            </DataGrid.ContextMenu>


        </DataGrid>


        <shared:Pagenation Grid.Row="4" />

    </Grid>
</UserControl>