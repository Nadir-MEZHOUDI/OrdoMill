<UserControl x:Class="OrdoMill.Views.Info.InfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dialog="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
             xmlns:extensions="clr-namespace:OrdoMill.Helpers.Extensions"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             dialog:DialogParticipation.Register="{Binding}"
             DataContext="{Binding Source={StaticResource Locator},
                                   Path=InfoViewModel}"
             Style="{DynamicResource CustomUserControl}"
             mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
            <TextBlock Margin="30,0,10,0"
                       VerticalAlignment="Center"
                       FontFamily="Sitka text"
                       FontSize="45"
                       FontStyle="Italic"
                       FontWeight="Bold"
                       Foreground="Green"
                       Text="{DynamicResource Pharmacie}"
                       TextAlignment="Center" />
        </StackPanel>
        <Grid Grid.Row="1" extensions:MarginSetter.Margin="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Label Grid.Row="1"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="{DynamicResource PharmacieD}" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Pharmacie,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="2"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="{DynamicResource AddressD}" />
            <TextBox Grid.Row="2"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Adresse,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="3"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="{DynamicResource Tele}" />
            <TextBox Grid.Row="3"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Tel,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="4"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="{DynamicResource Fax}" />
            <TextBox Grid.Row="4"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Fax,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="5"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="Code Fiscal:" />
            <TextBox Grid.Row="5"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.CodeFiscal,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="6"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="Article:" />
            <TextBox Grid.Row="6"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Article,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="7"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="RC:" />
            <TextBox Grid.Row="7"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Rc,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="8"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="CCP:" />
            <TextBox Grid.Row="8"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Ccp,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="9"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="Doit:" />
            <TextBox Grid.Row="9"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Doit,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="10"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="Region:" />
            <TextBox Grid.Row="10"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Region,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Label Grid.Row="11"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Content="Code:" />
            <TextBox Grid.Row="11"
                     Grid.Column="1"
                     VerticalAlignment="Center"
                     Text="{Binding SelectedItem.Code,
                                    Mode=TwoWay,
                                    UpdateSourceTrigger=PropertyChanged,
                                    NotifyOnValidationError=True,
                                    ValidatesOnDataErrors=True}" />
            <Button Grid.Row="12"
                    Grid.Column="1"
                    Margin="10"
                    VerticalAlignment="Center"
                    Command="{Binding SaveCommand}"
                    Style="{DynamicResource AccentedSquareButtonStyle}">
                <StackPanel Orientation="Horizontal">
                    <ContentControl Width="25"
                                    Margin="10,0"
                                    Content="{DynamicResource Save}" />
                    <TextBlock FontWeight="Bold" Text="{DynamicResource SaveTxt}" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>

</UserControl>
