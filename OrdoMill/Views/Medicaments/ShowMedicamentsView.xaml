<UserControl x:Class="OrdoMill.Views.Medicaments.ShowMedicamentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:extensions="clr-namespace:OrdoMill.Helpers.Extensions"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shared="clr-namespace:OrdoMill.Views.Shared"
             d:DataContext="{Binding Source={StaticResource Locator},
                                     Path=MedicamentsViewModel}"
             d:DesignHeight="500"
             d:DesignWidth="1000"
             Style="{DynamicResource CustomUserControl}"
             mc:Ignorable="d">
    <Grid extensions:MarginSetter.Margin="3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox IsEnabled="{Binding IsEditable,
                                     Converter={StaticResource BoolInverser}}"
                 Style="{DynamicResource SearshTextStyle}"
                 Text="{Binding SearchPattern,
                                UpdateSourceTrigger=PropertyChanged,
                                Mode=TwoWay}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="TextChanged">
                    <i:InvokeCommandAction Command="{Binding SearchCommand, UpdateSourceTrigger=PropertyChanged}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </TextBox>
        <StackPanel Grid.Column="1"
                    extensions:MarginSetter.Margin="3"
                    Orientation="Horizontal">
            <CheckBox Content="{DynamicResource Nc}" IsChecked="{Binding IncludeNc}" />

            <CheckBox Content="{DynamicResource Generique}" IsChecked="{Binding IncludeGen}" />

            <CheckBox Content="{DynamicResource Dci}" IsChecked="{Binding IncludeDci}" />
            <CheckBox Content="{DynamicResource Dose}" IsChecked="{Binding IncludeDose}" />
            <CheckBox Content="{DynamicResource Forme}" IsChecked="{Binding IncludeForm}" />
        </StackPanel>
        <DataGrid Grid.Row="2"
                  AlternatingRowBackground="{DynamicResource AccentColorBrush4}"
                  Grid.ColumnSpan="2"
                  IsEnabled="{Binding IsEditable,
                                      Converter={StaticResource BoolInverser}}"
                  ItemsSource="{Binding ListToDisplay}"
                  SelectedValue="{Binding SelectedItem}">
            <DataGrid.Columns>
                <!--<DataGridTextColumn Width="Auto"
                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                      Converter={converters:RowToIndexConverter}}"
                                    Header="{DynamicResource Num}"
                                    IsReadOnly="True" />-->
                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding Id}"
                                    Header="{DynamicResource Num}" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Nom}"
                                    FontWeight="Bold"
                                    Header="{DynamicResource Nc}"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Dci}"
                                    Header="{DynamicResource Dci}"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding Dose}"
                                    Header="{DynamicResource Dose}"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding Forme.Abrg}"
                                    Header="{DynamicResource Forme}" />
                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding Boite}"
                                    Header="{DynamicResource Boite}" />
            </DataGrid.Columns>
        </DataGrid>
        <shared:Pagenation Grid.Row="3" Grid.ColumnSpan="2" />

    </Grid>
</UserControl>
