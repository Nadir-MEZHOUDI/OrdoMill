<UserControl x:Class="OrdoMill.Views.Patients.ShowPatientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:command="http://www.galasoft.ch/mvvmlight"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:extensions="clr-namespace:SmartApp.Helpers.Extensions;assembly=SmartApp.Helpers"
             xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shared="clr-namespace:OrdoMill.Views.Shared"
             d:DataContext="{Binding Source={StaticResource Locator},
                                     Path=PatientsViewModel}"
             d:DesignHeight="500"
             d:DesignWidth="1000"
             Style="{DynamicResource CustomUserControl}"
             mc:Ignorable="d">
    <Grid extensions:MarginSetter.Margin="3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox IsEnabled="{Binding IsEditable,
                                     Converter={StaticResource BoolInverser}}"
                 Style="{DynamicResource SearshTextStyle}"
                 Text="{Binding SearchPattern,
                                UpdateSourceTrigger=PropertyChanged,
                                Mode=TwoWay}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="TextChanged">
                    <command:EventToCommand Command="{Binding SearchCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </TextBox>
        <DataGrid Grid.Row="1"
                  IsEnabled="{Binding IsEditable,
                                      Converter={StaticResource BoolInverser}}"
                  ItemsSource="{Binding ListToDisplay}"
                  SelectedValue="{Binding SelectedItem}">

            <DataGrid.Columns>

                <DataGridCheckBoxColumn Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected, Mode=OneWay}" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Assure.Matricule}"
                                    FontWeight="Bold"
                                    Header="Matricul">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Width="28"
                                            Height="28"
                                            Margin="10,0"
                                            Content="{DynamicResource Patient-01-Wf}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="*"
                                    Binding="{Binding FullName}"
                                    Header="{DynamicResource Patient}" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Assure.FullName,
                                                      Mode=OneWay}"
                                    Header="{DynamicResource Assure}" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Alliance,
                                                      Mode=OneWay,
                                                      Converter={StaticResource RelationshipConverter}}"
                                    FontWeight="Bold" />
                <DataGridTemplateColumn Width=".5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ToggleButton IsChecked="{Binding Activé, Mode=OneWay}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <WrapPanel HorizontalAlignment="Center"
                                       Background="Transparent"
                                       Visibility="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                            Path=IsMouseOver,
                                                            Converter={StaticResource VisibileToHiddenConverter}}">
                                <WrapPanel.Resources>
                                    <ResourceDictionary Source="../../Resources/Styles/BarButtonsStyle.xaml" />
                                </WrapPanel.Resources>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.AddCommand}">
                                    <ContentControl Content="{DynamicResource Add}" />
                                </Button>

                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.UpdateCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Editor}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.DeleteCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Recycle-Bin}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.GoToDetailsPage}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Preview}" />
                                </Button>
                            </WrapPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="{Binding AddCommand}"
                              Header="{DynamicResource Addtxt}"
                              Icon="{DynamicResource Add}" />
                    <MenuItem Command="{Binding UpdateCommand}"
                              Header="{DynamicResource Edit}"
                              Icon="{DynamicResource Editor}" />
                    <Separator />
                    <MenuItem Command="{Binding DeleteCommand}"
                              Header="{DynamicResource Del}"
                              Icon="{DynamicResource Recycle-Bin}" />
                    <Separator />
                    <MenuItem Command="{Binding SuspendCommand}"
                              Header="{DynamicResource Suspender}"
                              Icon="{DynamicResource BlockUser}" />

                    <MenuItem Command="{Binding UnSuspendCommand}"
                              Header="{DynamicResource UnSuspender}"
                              Icon="{DynamicResource UnBlock}" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
        <shared:Pagenation Grid.Row="2" />


    </Grid>
</UserControl>