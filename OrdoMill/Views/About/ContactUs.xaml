<UserControl
    x:Class="OrdoMill.Views.About.ContactUs"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialog="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
    xmlns:extensions="clr-namespace:OrdoMill.Helpers.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="500"
    d:DesignWidth="500"
    dialog:DialogParticipation.Register="{Binding}"
    DataContext="{Binding ContactUsViewModel, Source={StaticResource Locator}}"
    FlowDirection="{DynamicResource Direction}"
    FontSize="17"
    FontStyle="Italic"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="10*" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <GroupBox
            Grid.Column="1"
            Margin="20"
            Header="{DynamicResource ContactUsText}">
            <Grid extensions:MarginSetter.Margin="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{DynamicResource TitleText}" />
                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Text="{Binding SubjectText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1" Text="{DynamicResource NomD}" />
                <TextBox
                    Grid.Row="1"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="{Binding SenderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="2" Text="{DynamicResource Email}" />
                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="{Binding SenderEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock
                    Grid.Row="3"
                    VerticalAlignment="Top"
                    Text="{DynamicResource MsgBody}" />

                <TextBox
                    Grid.Row="3"
                    Grid.Column="1"
                    VerticalAlignment="Stretch"
                    Text="{Binding MessageBody, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button
                    Grid.Row="4"
                    Grid.Column="1"
                    Margin="40,10"
                    Command="{Binding SendCommand}">
                    <WrapPanel Height="30">
                        <ContentControl
                            Height="20"
                            VerticalAlignment="Center"
                            Content="{DynamicResource Mail-Forward}"
                            FlowDirection="{DynamicResource Direction}" />
                        <TextBlock
                            Margin="15,5"
                            VerticalAlignment="Center"
                            FontSize="15"
                            Text="{DynamicResource SendText}" />
                    </WrapPanel>
                </Button>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
