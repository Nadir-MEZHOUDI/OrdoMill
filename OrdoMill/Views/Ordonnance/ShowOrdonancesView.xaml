<UserControl x:Class="OrdoMill.Views.Ordonnance.ShowOrdonancesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:extensions="clr-namespace:SmartApp.Helpers.Extensions;assembly=SmartApp.Helpers"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shared="clr-namespace:OrdoMill.Views.Shared"
             d:DataContext="{Binding Source={StaticResource Locator},
                                     Path=OrdonancesViewModel}"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             Style="{DynamicResource CustomUserControl}"
             mc:Ignorable="d">
    <Grid extensions:MarginSetter.Margin="3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox IsEnabled="{Binding IsEditable,
                                     Converter={StaticResource BoolInverser}}"
                 Style="{DynamicResource SearshTextStyle}"
                 Text="{Binding Path=SearchPattern,
                                UpdateSourceTrigger=PropertyChanged,
                                Mode=TwoWay}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="TextChanged">
                    <i:InvokeCommandAction Command="{Binding SearchCommand, UpdateSourceTrigger=PropertyChanged}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </TextBox>
        <ComboBox Grid.Column="1"
                  DisplayMemberPath="Name"
                  FontWeight="Bold"
                  ItemsSource="{Binding FacturesList}"
                  SelectedItem="{Binding SelectedFacture,
                                         Mode=TwoWay,
                                         UpdateSourceTrigger=PropertyChanged}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="SelectionChanged">
                    <i:InvokeCommandAction Command="{Binding SearchCommand, UpdateSourceTrigger=PropertyChanged}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </ComboBox>
        <ListView Grid.Row="1"
                  Grid.ColumnSpan="2"
                  Grid.IsSharedSizeScope="True"
                  ItemsSource="{Binding ListToDisplay,
                                        UpdateSourceTrigger=PropertyChanged,
                                        Mode=TwoWay}"
                  SelectedValue="{Binding SelectedItem,
                                          Mode=TwoWay,
                                          UpdateSourceTrigger=PropertyChanged}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Height="35" d:DesignWidth="700">
                        <Border Style="{DynamicResource ItemListBorderStyle}" />
                        <Grid extensions:MarginSetter.Margin="5,1">
                            <Grid.Resources>
                                <Style TargetType="Control">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColNSS" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="ColMontan" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Margin="10,0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsCheck,
                                                          UpdateSourceTrigger=PropertyChanged,
                                                          Mode=TwoWay}" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="{Binding Patient.Assure.Matricule}"
                                       TextAlignment="Center" />
                            <ContentControl Grid.Column="2"
                                            Width="25"
                                            Height="25"
                                            Margin="10,0"
                                            Content="{DynamicResource OrdoIcon}" />
                            <TextBlock Grid.Column="3"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="{Binding Patient.FullName,
                                                      Mode=OneWay}" />


                            <!--<TextBlock Grid.Column="4"
                                       FontWeight="Bold"
                                       Text="{Binding Medecin.FullName}" />-->


                            <TextBlock Grid.Column="4"
                                       Margin="10,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding ServiDate,
                                                      StringFormat=dd/MM/yyyy}"
                                       TextAlignment="Center" />

                            <ContentControl Grid.Column="5"
                                            Width="25"
                                            Height="25"
                                            Margin="20,0"
                                            Background="{DynamicResource GrayBrush1}"
                                            Content="{DynamicResource MoneyIcon}" />

                            <TextBlock Grid.Column="6"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="{Binding Montant,
                                                      Mode=OneWay,
                                                      StringFormat=N2}"
                                       TextAlignment="Right" />

                            <TextBlock Grid.Column="7"
                                       Margin="0,0,20,0"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       Text="{DynamicResource CurrencyDz}" />

                            <CheckBox Grid.Column="8"
                                      VerticalAlignment="Center"
                                      Content="{DynamicResource Mc}"
                                      IsChecked="{Binding IsChronique}" />

                            <CheckBox Grid.Column="9"
                                      VerticalAlignment="Center"
                                      Content="{DynamicResource Hr}"
                                      IsChecked="{Binding IsHorsRegion}" />
                            <WrapPanel Grid.Column="10"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Background="Transparent"
                                       Visibility="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem},
                                                            Path=IsMouseOver,
                                                            Converter={StaticResource VisibileToHiddenConverter}}">
                                <WrapPanel.Resources>
                                    <ResourceDictionary Source="../../Resources/Styles/BarButtonsStyle.xaml" />
                                </WrapPanel.Resources>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.AddCommand}">
                                    <ContentControl Content="{DynamicResource Add}" />
                                </Button>

                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.UpdateCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Editor}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.DeleteCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Recycle-Bin}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.ShowDetailsCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Preview}" />
                                </Button>
                            </WrapPanel>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>
        <!--<TextBlock Grid.Row="2"
                   Grid.ColumnSpan="2"
                   Margin="5,0"

                   Text="{Binding StatusText}" />-->
        <shared:Pagenation Grid.Row="3" Grid.ColumnSpan="2" />
    </Grid>
</UserControl>