<UserControl x:Class="OrdoMill.Views.Ordonnance.OrdonanaceDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:reportes="clr-namespace:OrdoMill.Views.Reportes"
             d:DataContext="{Binding Source={StaticResource Locator},
                                     Path=OrdonancesViewModel.SelectedItem}"
             d:DesignHeight="800"
             d:DesignWidth="600"
             Style="{StaticResource CustomUserControl}"
             mc:Ignorable="d">

    <TabControl>
        <TabItem IsSelected="True">
            <TabItem.Header>
                <TextBlock Width="200"
                           Margin="0,-5"
                           FontWeight="Bold"
                           Text="{DynamicResource Facture}"
                           TextAlignment="Center" />
            </TabItem.Header>
            <Grid FlowDirection="LeftToRight">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid Background="{DynamicResource MahApps.Brushes.Accent}" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />

                    </Grid.ColumnDefinitions>
                    <Grid.Resources>
                        <ResourceDictionary Source="../../Resources/Styles/BarButtonsStyle.xaml" />
                    </Grid.Resources>
                    <Button Grid.Column="1"
                            Command="{Binding StaticServices.QPrintCommand,
                                              Source={StaticResource Locator}}"
                            CommandParameter="{Binding ElementName=MyFactur,
                                                       Path=Content}">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Margin="10,0" Content="{DynamicResource Print-01}" />
                            <TextBlock Text="{DynamicResource QPrint}" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3"
                            Command="{Binding StaticServices.PrintCommand,
                                              Source={StaticResource Locator}}"
                            CommandParameter="{Binding ElementName=MyFactur,
                                                       Path=Content}">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Content="{DynamicResource Document-Settings-01}" />
                            <TextBlock Text="{DynamicResource Print}" />
                        </StackPanel>
                    </Button>

                </Grid>
                <reportes:FactureView x:Name="MyFactur"
                                      Grid.Row="1"
                                      Margin="10"
                                      FlowDirection="LeftToRight" />
            </Grid>
        </TabItem>
        <TabItem>
            <TabItem.Header>
                <TextBlock Width="200"
                           Margin="0,-5"
                           FontWeight="Bold"
                           Text="{DynamicResource Info}"
                           TextAlignment="Center" />
            </TabItem.Header>
            <Grid FlowDirection="LeftToRight">
                <Grid.Resources>
                    <ResourceDictionary Source="../../Resources/Styles/ButtonsStyle.xaml" />
                </Grid.Resources>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid Background="{DynamicResource MahApps.Brushes.Accent}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />

                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />

                    </Grid.ColumnDefinitions>
                    <Grid.Resources>
                        <ResourceDictionary Source="../../Resources/Styles/BarButtonsStyle.xaml" />
                    </Grid.Resources>
                    <Button Grid.Column="1"
                            Height="30"
                            Command="{Binding StaticServices.QPrintCommand,
                                              Source={StaticResource Locator}}"
                            CommandParameter="{Binding ElementName=MyOrdonnance,
                                                       Path=Content}"
                            FontSize="15">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Margin="10,0" Content="{DynamicResource Print-01}" />
                            <TextBlock Text="{DynamicResource QPrint}" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="3"
                            Height="30"
                            Command="{Binding StaticServices.PrintCommand,
                                              Source={StaticResource Locator}}"
                            CommandParameter="{Binding ElementName=MyOrdonnance,
                                                       Path=Content}"
                            FontSize="15">
                        <StackPanel Orientation="Horizontal">
                            <ContentControl Content="{DynamicResource Document-Settings-01}" />
                            <TextBlock Text="{DynamicResource Print}" />
                        </StackPanel>
                    </Button>
                </Grid>
                <reportes:OrdonanceInfoView x:Name="MyOrdonnance"
                                            Grid.Row="1"
                                            Margin="10"
                                            FlowDirection="LeftToRight" />
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
