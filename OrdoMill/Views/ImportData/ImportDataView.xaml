<UserControl x:Class="OrdoMill.Views.ImportData.ImportDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dialog="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="500"
             d:DesignWidth="500"
             dialog:DialogParticipation.Register="{Binding}"
             Style="{StaticResource CustomUserControl}"
             mc:Ignorable="d">

    <StackPanel Width="200" Margin="10">
        <Button Margin="10"
                Click="ImportMedicamentsBtn_OnClick"
                Content="Import Medicaments" />
        <Button Margin="10"
                Click="ImportSpecialitesBtn_OnClick"
                Content="Import Spécialités" />
        <Button Margin="10"
                Click="ImportFormesBtn_OnClick"
                Content="Import Formes" />
        <Button Margin="10"
                Click="ImportAssuresBtn_OnClick"
                Content="Import Assures" />
        <Button Margin="10"
                Click="ExportAssuresBtn_OnClick"
                Content="Export Assures" />
        <ProgressBar Height="20" Value="{Binding ProgressIndicator, UpdateSourceTrigger=PropertyChanged}" />
    </StackPanel>
</UserControl>