<UserControl x:Class="OrdoMill.Views.Reportes.FactureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{Binding Source={StaticResource Locator},
                                     Path=SelectedOrdonnance}"
             mc:Ignorable="d">
    <ScrollViewer>
        <Grid MaxWidth="14cm"
              MaxHeight="20cm"
              Background="White"
              FlowDirection="LeftToRight">
            <Canvas Width="14cm"
                    Height="19cm"
                    FlowDirection="LeftToRight">
                <Border Margin="25"
                        BorderBrush="Black"
                        BorderThickness="1">
                    <Border Height="665"
                            Margin="2"
                            BorderBrush="Black"
                            BorderThickness="1">
                        <Grid Width="12cm"
                              Height="18cm"
                              Margin="5"
                              FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="1"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Officine:" />

                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Grid.ColumnSpan="3"
                                     VerticalAlignment="Stretch"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding InfoViewModel.SelectedItem.Pharmacie,
                                                    Source={StaticResource Locator}}"
                                     TextAlignment="Center" />

                            <TextBox Grid.Row="2"
                                     Grid.ColumnSpan="5"
                                     Margin="10"
                                     VerticalContentAlignment="Top"
                                     controls:TextBoxHelper.ClearTextButton="False"
                                     BorderThickness="2"
                                     FontSize="20"
                                     FontWeight="Bold"
                                     IsReadOnly="True"
                                     Text="LISTE DES MEDICAMENTS SERVIS"
                                     TextAlignment="Center" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="2"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="N°Facture:" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="4"
                                     VerticalAlignment="Stretch"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Id}" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="2"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Date Facture:" />
                            <TextBox Grid.Row="5"
                                     Grid.Column="4"
                                     VerticalAlignment="Stretch"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding ServiDate,
                                                    StringFormat='{}{0:dd/MM/yyyy}'}" />
                            <TextBlock Grid.Row="6"
                                       Grid.Column="2"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Date de soin:" />
                            <TextBox Grid.Row="6"
                                     Grid.Column="4"
                                     VerticalAlignment="Stretch"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding SoineDate,
                                                    StringFormat='{}{0:dd/MM/yyyy}'}" />

                            <TextBlock Grid.Row="8"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Nom et Prénom de l'assuré:" />
                            <TextBox Grid.Row="8"
                                     Grid.Column="2"
                                     Grid.ColumnSpan="3"
                                     VerticalAlignment="Stretch"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Patient.Assure.FullName,
                                                    Mode=OneWay}" />
                            <TextBlock Grid.Row="9"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Numerous d'immatriculation:" />
                            <TextBox Grid.Row="9"
                                     Grid.Column="2"
                                     Grid.ColumnSpan="3"
                                     VerticalAlignment="Stretch"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Patient.Assure.Matricule,
                                                    UpdateSourceTrigger=PropertyChanged,
                                                    Mode=TwoWay}" />
                            <TextBlock Grid.Row="10"
                                       Grid.ColumnSpan="2"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Nom et prénom du malade:" />
                            <TextBox Grid.Row="10"
                                     Grid.Column="2"
                                     Grid.ColumnSpan="3"
                                     VerticalAlignment="Stretch"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Patient.FullName,
                                                    Mode=OneWay,
                                                    UpdateSourceTrigger=PropertyChanged}" />
                            <Border Grid.Row="11"
                                    Grid.ColumnSpan="5"
                                    Margin="5,15,5,25"
                                    BorderBrush="Black"
                                    BorderThickness="2">
                                <DataGrid AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          ColumnHeaderHeight="30"
                                          FontSize="15"
                                          ItemsSource="{Binding Medicaments,
                                                                UpdateSourceTrigger=PropertyChanged}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="*"
                                                            Binding="{Binding Medicament.FullName}"
                                                            Header="Medicament Servis"
                                                            IsReadOnly="True" />
                                        <DataGridTextColumn Width="Auto"
                                                            Binding="{Binding Ppa}"
                                                            Header="P.U" />
                                        <DataGridTextColumn Width="Auto"
                                                            Binding="{Binding Quantite}"
                                                            Header="Qt"
                                                            IsReadOnly="True" />
                                        <DataGridTextColumn Width="Auto"
                                                            Binding="{Binding Montant}"
                                                            Header="Montant" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <TextBlock Grid.Row="12"
                                       Grid.Column="2"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Montant facture:" />
                            <TextBox Grid.Row="12"
                                     Grid.Column="3"
                                     Grid.ColumnSpan="2"
                                     Margin="10,5"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Montant,
                                                    Mode=OneWay,
                                                    UpdateSourceTrigger=PropertyChanged,
                                                    StringFormat=\{0:F\}}"
                                     TextAlignment="Center" />
                        </Grid>
                    </Border>
                </Border>
            </Canvas>
        </Grid>

    </ScrollViewer>
</UserControl>