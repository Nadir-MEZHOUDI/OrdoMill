<UserControl x:Class="OrdoMill.Views.Reportes.OrdonanceInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{Binding Source={StaticResource Locator},
                                     Path=VentViewModel.SelectedItem}"
             mc:Ignorable="d">
    <ScrollViewer>
        <Grid MaxWidth="20cm"
              MaxHeight="19cm"
              Background="White"
              FlowDirection="LeftToRight"
              ShowGridLines="True">
            <Canvas Width="14cm"
                    Height="19cm"
                    Margin="1,0,-1.2,0.4"
                    FlowDirection="LeftToRight">
                <Border MinWidth="460"
                        Margin="30"
                        BorderBrush="Black"
                        BorderThickness="0">
                    <Border Margin="2"
                            BorderBrush="White"
                            BorderThickness="1">
                        <Grid Width="Auto"
                              Margin="5"
                              FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="N°SS:" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Patient.Assure.Matricule,
                                                    Mode=OneWay,
                                                    StringFormat='{}{0:###.###}',
                                                    UpdateSourceTrigger=PropertyChanged}"
                                     TextAlignment="Center" />

                            <TextBlock Grid.Row="1"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Assuré:" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Patient.Assure.FullName,
                                                    Mode=OneWay,
                                                    UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Né le:" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     FontSize="18"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Patient.Assure.DateNaissance,
                                                    Mode=OneWay,
                                                    StringFormat='{}{0:dd/MM/yyyy}'}" />
                            <TextBlock Grid.Row="3"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Adresse:" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Patient.Assure.Adresse}" />
                            <TextBlock Grid.Row="4"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Patient:" />
                            <TextBox Grid.Row="4"
                                     Grid.Column="1"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Patient.FullName,
                                                    Mode=OneWay,
                                                    UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="5"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="jusqu'au:" />
                            <TextBox Grid.Row="5"
                                     Grid.Column="1"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding Patient.Au,
                                                    StringFormat='{}{0:dd/MM/yyyy}'}" />
                            <TextBlock Grid.Row="6"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Servi Le:" />
                            <TextBox Grid.Row="6"
                                     Grid.Column="1"
                                     FontSize="18"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding ServiDate,
                                                    StringFormat='{}{0:dd/MM/yyyy}'}" />
                            <TextBlock Grid.Row="7"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Totale:" />
                            <TextBox Grid.Row="7"
                                     Grid.Column="1"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding MontantString,
                                                    Mode=OneWay,
                                                    UpdateSourceTrigger=PropertyChanged}"
                                     TextAlignment="Center" />
                            <TextBlock Grid.Row="8"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Vignettes:" />
                            <TextBox Grid.Row="8"
                                     Grid.Column="1"
                                     Style="{StaticResource GreenText}"
                                     Text="{Binding VignettesString,
                                                    Mode=OneWay}"
                                     TextAlignment="Center" />
                            <TextBlock Grid.Row="9"
                                       Style="{StaticResource CardTextStyle}"
                                       Text="Signature:" />
                            <TextBox Grid.Row="9"
                                     Grid.Column="1"
                                     Style="{StaticResource GreenText}"
                                     TextAlignment="Center" />
                        </Grid>
                    </Border>
                </Border>
            </Canvas>
        </Grid>

    </ScrollViewer>

</UserControl>