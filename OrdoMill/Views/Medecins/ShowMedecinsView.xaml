<UserControl x:Class="OrdoMill.Views.Medecins.ShowMedecinsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:command="http://www.galasoft.ch/mvvmlight"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:extensions="clr-namespace:SmartApp.Helpers.Extensions;assembly=SmartApp.Helpers"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shared="clr-namespace:OrdoMill.Views.Shared"
             d:DataContext="{Binding Source={StaticResource Locator},
                                     Path=MedecinsViewModel}"
             d:DesignHeight="700"
             d:DesignWidth="1400"
             Style="{DynamicResource CustomUserControl}"
             mc:Ignorable="d">

    <Grid extensions:MarginSetter.Margin="3">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox IsEnabled="{Binding IsEditable,
                                     Converter={StaticResource BoolInverser}}"
                 Style="{DynamicResource SearshTextStyle}"
                 Text="{Binding Path=SearchPattern,
                                UpdateSourceTrigger=PropertyChanged,
                                Mode=TwoWay}">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="TextChanged">
                    <command:EventToCommand Command="{Binding SearchCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </TextBox>
        <DataGrid Grid.Row="1"
                  Grid.ColumnSpan="2"
                  ItemsSource="{Binding ListToDisplay}"
                  SelectedValue="{Binding SelectedItem}">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Width="28"
                                            Height="28"
                                            Margin="15,0"
                                            Content="{DynamicResource Doctor}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding Nom,
                                                      StringFormat=Dr.{0}}"
                                    FontSize="15"
                                    FontWeight="Bold" />

                <DataGridTextColumn Width="0.5*" Binding="{Binding Type, Converter={StaticResource MedecinsTypesConvertr}, Mode=OneWay}" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Width="28"
                                            Height="28"
                                            Margin="10,0"
                                            Content="{DynamicResource Summation}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="0.5*"
                                    Binding="{Binding Ordonnances.Count,
                                                      Mode=OneWay}"
                                    FontWeight="Bold" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Tel,
                                                      Mode=OneWay}"
                                    FontWeight="Bold" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Adresse,
                                                      Mode=OneWay}"
                                    FontWeight="Bold" />
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <WrapPanel HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Background="Transparent"
                                       Visibility="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                            Path=IsMouseOver,
                                                            Converter={StaticResource VisibileToHiddenConverter}}">
                                <WrapPanel.Resources>
                                    <ResourceDictionary Source="../../Resources/Styles/BarButtonsStyle.xaml" />
                                </WrapPanel.Resources>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.AddCommand}">
                                    <ContentControl Content="{DynamicResource Add}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.UpdateCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Editor}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.DeleteCommand}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Recycle-Bin}" />
                                </Button>
                                <Button Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.GoToDetailsPage}" CommandParameter="{Binding Id}">
                                    <ContentControl Content="{DynamicResource Preview}" />
                                </Button>
                            </WrapPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <!--<DataGrid Grid.Row="1"
                  AlternationCount="2"
                  IsEnabled="{Binding IsEditable,
                                      Converter={StaticResource BoolInverser}}"
                  ItemsSource="{Binding ListToDisplay}"
                  SelectedValue="{Binding SelectedItem}"
                  Style="{StaticResource DataGridStyle}">
            <DataGrid.Columns>
        -->
        <!--<DataGridTextColumn Width="Auto"
                                    Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                      Converter={converters:RowToIndexConverter}}"
                                    Header="{DynamicResource Num}"
                                    IsReadOnly="True" />-->
        <!--
                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding Id}"
                                    Header="{DynamicResource Num}"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Nom}"
                                    FontWeight="Bold"
                                    Header="{DynamicResource LastName}"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Type,
                                                      Converter={StaticResource MedecinsTypesConvertr}}"
                                    Header="{DynamicResource Specialite}" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Tel}"
                                    Header="{DynamicResource Tele}" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding Ordonnances.Count}"
                                    Header="{DynamicResource Ordonnances}" />

            </DataGrid.Columns>
        </DataGrid>-->
        <shared:Pagenation Grid.Row="2" />
    </Grid>

</UserControl>