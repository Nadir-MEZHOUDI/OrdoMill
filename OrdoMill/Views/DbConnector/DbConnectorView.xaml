<controls:MetroWindow
    x:Class="OrdoMill.Views.DbConnector.DbConnectorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialog="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
    xmlns:extensions="clr-namespace:OrdoMill.Helpers.Extensions"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    dialog:DialogParticipation.Register="{Binding}"
    Closing="DbConnectorView_OnClosing"
    DataContext="{Binding DbConnectorVm, Source={StaticResource Locator}}"
    ShowTitleBar="True"
    SizeToContent="WidthAndHeight"
    Style="{DynamicResource CustomWindow}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <ScrollViewer>
        <Grid extensions:MarginSetter.Margin="3">
            <StackPanel extensions:MarginSetter.Margin="3" Grid.IsSharedSizeScope="True">
                <TabControl>
                    <TabItem IsSelected="{Binding IsInNetwork, Converter={StaticResource BoolInverser}}">
                        <TabItem.Header>
                            <WrapPanel Margin="10,0">
                                <ContentControl
                                    Height="20"
                                    Margin="10,0"
                                    Content="{DynamicResource Computer-Desktop}" />
                                <TextBlock Text="Computer" />
                            </WrapPanel>
                        </TabItem.Header>
                        <Grid extensions:MarginSetter.Margin="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="A" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Label Content="Server:" />
                            <ComboBox
                                Grid.Row="0"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                IsEditable="True"
                                ItemsSource="{Binding SuggestedList}"
                                Text="{Binding ServerName, Mode=TwoWay}" />

                        </Grid>
                    </TabItem>
                    <TabItem IsSelected="{Binding IsInNetwork}">
                        <TabItem.Header>
                            <WrapPanel Margin="10,0">
                                <ContentControl
                                    Height="20"
                                    Margin="10,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource ManyComputers}" />
                                <TextBlock VerticalAlignment="Center" Text="Network" />
                            </WrapPanel>
                        </TabItem.Header>
                        <Grid extensions:MarginSetter.Margin="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />

                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="A" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Button
                                Margin="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Command="{Binding GetNetworkPCs}">
                                <ContentControl Margin="4" Content="{DynamicResource NetworkIcon}" />
                            </Button>
                            <ComboBox
                                Grid.Column="1"
                                controls:TextBoxHelper.ButtonCommand="{Binding GetNetworkPCs}"
                                ItemsSource="{Binding NetworkPCs, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                Text="{Binding ServerName}">
                                <controls:TextBoxHelper.ButtonContent>
                                    <ContentControl
                                        Margin="4"
                                        Background="{DynamicResource MahApps.Brushes.Gray1}"
                                        Content="{DynamicResource NetworkIcon}" />
                                </controls:TextBoxHelper.ButtonContent>
                            </ComboBox>
                            <!--<CheckBox Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="20,3"
                                  Content="استخدم المنفذ"
                                  IsChecked="{Binding UsePort,
                                                      Mode=TwoWay}" />-->
                            <controls:MetroProgressBar
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="40,0"
                                IsIndeterminate="{Binding IsSearchingPCs}" />
                            <Label Grid.Row="2" Content="Port:" />
                            <mah:NumericUpDown
                                Grid.Row="2"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                TextAlignment="Center"
                                Value="{Binding Port}" />
                        </Grid>
                    </TabItem>
                </TabControl>
                <GroupBox>
                    <Grid extensions:MarginSetter.Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="A" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <WrapPanel Grid.Column="1">
                            <RadioButton
                                Margin="5,3"
                                Content="Windows Authentication"
                                GroupName="a"
                                IsChecked="{Binding IntegratedSecurity, Mode=TwoWay}"
                                d:LayoutOverrides="LeftPosition, RightPosition" />
                            <RadioButton
                                Margin="5,3"
                                Content="PostgreSQL Authentication"
                                GroupName="a"
                                IsChecked="{Binding IntegratedSecurity, Converter={StaticResource BoolInverser}, Mode=TwoWay}" />
                        </WrapPanel>
                        <Label
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            Content="Mode:" />
                        <Label
                            Grid.Row="1"
                            Content="User name:"
                            Visibility="{Binding SqlSecurity, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />

                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsEnabled="{Binding SqlSecurity, Mode=OneWay}"
                            Text="{Binding UserName, Mode=TwoWay}"
                            Visibility="{Binding SqlSecurity, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />
                        <Label
                            Grid.Row="2"
                            Content="Password:"
                            Visibility="{Binding SqlSecurity, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />

                        <PasswordBox
                            Grid.Row="2"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            controls:TextBoxHelper.ClearTextButton="True"
                            extensions:PasswordHelper.Attach="True"
                            extensions:PasswordHelper.Password="{Binding Password, Mode=TwoWay}"
                            IsEnabled="{Binding SqlSecurity, Mode=OneWay}"
                            Visibility="{Binding SqlSecurity, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />

                    </Grid>
                </GroupBox>
                <GroupBox extensions:MarginSetter.Margin="3">
                    <Grid extensions:MarginSetter.Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="A" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />

                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Content="Source:" />
                        <WrapPanel Grid.Row="0" Grid.Column="1">
                            <RadioButton
                                Margin="10,3"
                                Content="Database Name:"
                                GroupName="b"
                                IsChecked="{Binding IsAttached, Converter={StaticResource BoolInverser}, Mode=TwoWay}" />
                            <RadioButton
                                Margin="10,3"
                                Content="Database file:"
                                GroupName="b"
                                IsChecked="{Binding IsAttached, Mode=TwoWay}" />
                        </WrapPanel>
                        <Label
                            Grid.Row="1"
                            Content="Database Name:"
                            Visibility="{Binding IsNotAttached, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />
                        <ComboBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="3"
                            controls:TextBoxHelper.ButtonCommand="{Binding GetServerDBs}"
                            IsEditable="True"
                            IsEnabled="{Binding IsNotAttached, Mode=OneWay}"
                            ItemsSource="{Binding Databases}"
                            Text="{Binding DbName, Mode=TwoWay}"
                            Visibility="{Binding IsNotAttached, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}">
                            <controls:TextBoxHelper.ButtonContent>
                                <ContentControl
                                    Margin="4"
                                    Background="{DynamicResource MahApps.Brushes.Gray1}"
                                    Content="{DynamicResource Data-Synchronize}" />
                            </controls:TextBoxHelper.ButtonContent>
                        </ComboBox>
                        <controls:MetroProgressBar
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="40,0"
                            IsIndeterminate="{Binding IsSearchingDbs}"
                            Visibility="{Binding IsNotAttached, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />
                        <CheckBox
                            Grid.Row="3"
                            Grid.Column="1"
                            Margin="40,3"
                            Content="Create database (if not exist)"
                            IsChecked="{Binding Create, Mode=TwoWay}"
                            IsEnabled="{Binding IsNotAttached, Mode=OneWay}"
                            Visibility="{Binding IsNotAttached, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />
                        <CheckBox
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="40,3"
                            Content="Delete database (if exist)"
                            IsChecked="{Binding Delete, Mode=TwoWay}"
                            IsEnabled="{Binding IsNotAttached, Mode=OneWay}"
                            Visibility="{Binding IsNotAttached, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />
                        <Label
                            Grid.Row="6"
                            Content="Database Path:"
                            Visibility="{Binding IsAttached, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />
                        <TextBox
                            Grid.Row="6"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            controls:TextBoxHelper.ButtonCommand="{Binding BrowsDbCommand}"
                            IsEnabled="{Binding IsAttached}"
                            Style="{DynamicResource MahApps.Styles.TextBox}"
                            Text="{Binding DbPath, Mode=TwoWay}"
                            Visibility="{Binding IsAttached, Converter={StaticResource VisibileToCollapsedConverter}, Mode=OneWay}" />
                    </Grid>
                </GroupBox>
                <Grid extensions:MarginSetter.Margin="5,5">
                    <Grid.Resources>
                        <ResourceDictionary Source="../../Resources/Styles/ButtonsStyle.xaml" />
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Row="0"
                        Grid.Column="0"
                        Command="{Binding CheckConCommand}">
                        <StackPanel>
                            <ContentControl Content="{DynamicResource Check-02}" />
                            <TextBlock Text="Test" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        Command="{Binding ResetConfigCommand}">
                        <StackPanel>
                            <ContentControl Content="{DynamicResource DataSettings}" />
                            <TextBlock Text="Default" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Row="1"
                        Grid.Column="0"
                        Command="{Binding SaveConfigCommand}">
                        <StackPanel>
                            <ContentControl Content="{DynamicResource Save}" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        Click="BtnClose">
                        <StackPanel>
                            <ContentControl Content="{DynamicResource Save}" />
                            <TextBlock Text="Exit" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
