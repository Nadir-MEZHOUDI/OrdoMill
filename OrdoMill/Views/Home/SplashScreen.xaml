<controls:MetroWindow
    x:Class="OrdoMill.Views.Home.SplashScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="600"
    Height="300"
    Background="{DynamicResource GrayBrush4}"
    ContentRendered="SplashScreen_OnContentRendered"
    FlowDirection="RightToLeft"
    GlowBrush="{DynamicResource AccentColorBrush}"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    ShowTitleBar="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Image
            Grid.RowSpan="3"
            Margin="15"
            FlowDirection="RightToLeft"
            Source="../../Resources/Icons/OrdoMill.png" />
        <!--<TextBlock FontSize="30" Text="{x:Static Res:Resources.Laungue}" />-->
        <controls:MetroProgressBar
            Grid.RowSpan="2"
            Grid.Column="1"
            Grid.ColumnSpan="2"
            VerticalAlignment="Center"
            IsIndeterminate="True" />
        <Viewbox
            Grid.Row="0"
            Grid.Column="1"
            Grid.ColumnSpan="2"
            Margin="10">
            <TextBlock
                Background="Transparent"
                FontFamily="../../Resources/Fonts/#Wendelin"
                FontSize="110"
                FontWeight="ExtraBold"
                Foreground="{DynamicResource AccentColorBrush}"
                Text="OrdoMill">
                <TextBlock.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform />
                        <SkewTransform AngleY="0.174" />
                        <RotateTransform />
                        <TranslateTransform Y="-0.561" />
                    </TransformGroup>
                </TextBlock.RenderTransform>
                <TextBlock.BitmapEffect>
                    <DropShadowBitmapEffect
                        Direction="190"
                        Opacity="0.5"
                        ShadowDepth="4"
                        Softness="0.25"
                        Color="Black" />
                </TextBlock.BitmapEffect>
            </TextBlock>
        </Viewbox>

        <Viewbox
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="2">
            <TextBlock
                Margin="40,0"
                Background="Transparent"
                FontSize="80"
                FontStyle="Italic"
                FontWeight="ExtraBold"
                Foreground="{DynamicResource GrayBrush8}"
                Text="SmartApp">
                <TextBlock.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform />
                        <SkewTransform AngleY="0.174" />
                        <RotateTransform />
                        <TranslateTransform Y="-0.561" />
                    </TransformGroup>
                </TextBlock.RenderTransform>
                <TextBlock.BitmapEffect>
                    <DropShadowBitmapEffect
                        Direction="220"
                        Opacity="0.5"
                        ShadowDepth="4"
                        Softness="0.25"
                        Color="Black" />
                </TextBlock.BitmapEffect>
            </TextBlock>
        </Viewbox>
    </Grid>
</controls:MetroWindow>