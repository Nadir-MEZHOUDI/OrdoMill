<UserControl
    x:Class="OrdoMill.Views.Home.LicenseView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="clr-namespace:SmartApp.Helpers.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DataContext="{Binding Source={StaticResource Locator}, Path=Main.LicenseDialog.ViewModel}"
    Background="Transparent"
    FlowDirection="RightToLeft"
    FontSize="16"
    Style="{DynamicResource CustomUserControl}"
    mc:Ignorable="d">
    <Grid Margin="5" extensions:MarginSetter.Margin="3">
        <Grid.RowDefinitions>
            <RowDefinition Height="90" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Viewbox>
                <TextBlock
                    Margin="5"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="التسجيل"
                    TextAlignment="Left"
                    TextTrimming="CharacterEllipsis" />
            </Viewbox>
            <Image
                Grid.Column="1"
                Margin="-10"
                Source="../../Resources/Icons/SmartApp_Logo.png" />
            <Viewbox Grid.Column="2">
                <TextBlock
                    Margin="5"
                    VerticalAlignment="Center"
                    FontFamily="MicroMieps Phat"
                    FontStyle="Italic"
                    FontWeight="Bold"
                    Text="SmartApp"
                    TextAlignment="Left"
                    TextTrimming="CharacterEllipsis" />
            </Viewbox>
        </Grid>
        <TextBlock Grid.Row="1" Text="معرف هذه النسخة هو:" />
        <TextBox
            Grid.Row="2"
            CharacterCasing="Upper"
            FontSize="15"
            FontWeight="Bold"
            Foreground="Black"
            IsReadOnly="True"
            Text="{Binding PrimaryKey, Mode=OneTime}"
            TextAlignment="Center" />
        <TextBlock
            Grid.Row="3"
            HorizontalAlignment="Center"
            Text="فضلا قم بإدخال الرقم التسلسلي للمنتج" />
        <TextBox
            Grid.Row="4"
            controls:TextBoxHelper.Watermark="أدخل الرقم التسلسلي..."
            CharacterCasing="Upper"
            FontSize="15"
            FontWeight="Bold"
            Foreground="Black"
            Text="{Binding FinalKey}"
            TextAlignment="Center" />


        <Grid Grid.Row="5" extensions:MarginSetter.Margin="3">
            <Grid.Resources>
                <ResourceDictionary Source="../../Resources/Styles/ButtonsStyle.xaml" />
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Command="{Binding HideDialogCommand}">
                <StackPanel>
                    <ContentControl
                        Width="20"
                        Height="20"
                        Content="{DynamicResource DateImage}" />
                    <TextBlock FontSize="17" Text=" تجريب " />
                </StackPanel>
            </Button>
            <Button Grid.Column="1" Command="{Binding HideDialogIfPossibleCommand}">
                <StackPanel>
                    <ContentControl
                        Width="20"
                        Height="20"
                        Content="{DynamicResource Agreement-02}" />
                    <TextBlock FontSize="17" Text=" تسجيل " />
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Command="{Binding CloseCommand}">
                <StackPanel>
                    <ContentControl
                        Width="20"
                        Height="20"
                        Content="{DynamicResource Cancel}" />
                    <TextBlock FontSize="17" Text=" خروج " />
                </StackPanel>
            </Button>
        </Grid>

        <TextBlock
            Grid.Row="6"
            Margin="0,5"
            Text="{Binding OutputMessage}"
            TextAlignment="Center" />
    </Grid>
</UserControl>


